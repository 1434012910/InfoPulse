        },
        {
            "name": "腾讯新闻-App",
            "enabled": true,
            "type": "app",
            "method": "direct",
            "url": "https://i.news.qq.com/trpc.qqnews_web.kv_srv.kv_srv_http/list?sub_srv_id=24hours",
            "interval": 300,
            "retry_times": 3,
